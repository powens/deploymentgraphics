{
  "name": "deploymentgraphics",
  "version": "0.1.0",
  "description": "Render Warhammer 40k mission deployment maps as SVG from typed config.",
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./presets": {
      "types": "./lib/presets/index.d.ts",
      "import": "./lib/presets/index.js"
    }
  },
  "files": [
    "lib"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "test": "vitest run",
    "build": "rollup --config rollup.config.mjs",
    "build-gh": "pnpm run build",
    "build:lib": "rimraf lib && tsc -p tsconfig.build.json",
    "gen:presets": "node scripts/gen-presets.mjs",
    "gen:presets:check": "node scripts/gen-presets.mjs --check",
    "convert:40kdc": "node scripts/convert-40kdc-terrain.mjs",
    "convert:40kdc:check": "node scripts/convert-40kdc-terrain.mjs --check",
    "serve": "rollup --config rollup.config.mjs --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "pnpm run gen:presets:check && pnpm run lint && pnpm run type-check && pnpm run test && pnpm run build:lib"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/powens/deploymentgraphics.git"
  },
  "keywords": [
    "warhammer",
    "40k",
    "warhammer-40k",
    "svg",
    "deployment-map",
    "wargaming",
    "tabletop"
  ],
  "author": "Patrick (https://github.com/powens)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/powens/deploymentgraphics/issues"
  },
  "homepage": "https://github.com/powens/deploymentgraphics#readme",
  "peerDependencies": {
    "happy-dom": ">=15"
  },
  "peerDependenciesMeta": {
    "happy-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.3",
    "js-yaml": "^4.2.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.0",
    "rollup-plugin-auto-reload": "^2.0.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-serve": "^3.0.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
