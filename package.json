  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.0",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.25.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "rollup": "^4.60.4",
    "rollup-plugin-auto-reload": "^2.0.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-serve": "^3.0.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
